#!/usr/bin/env bash
# post-commit hook: auto-push to remote after every local commit
set -uo pipefail

branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || exit 0
remote="$(git config --get "branch.${branch}.remote" 2>/dev/null)" || remote="origin"

printf "post-commit: pushing %s to %s...\n" "${branch}" "${remote}"
git push "${remote}" "${branch}" 2>&1 || printf "post-commit: push failed (rc=%d)\n" $?
