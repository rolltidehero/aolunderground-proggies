{
  "name": "default",
  "description": "Default agent with nohup enforcement hook",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "grep",
    "glob",
    "code",
    "web_search",
    "web_fetch",
    "use_aws",
    "introspect",
    "use_subagent",
    "report_issue"
  ],
  "allowedTools": [
    "fs_read",
    "grep",
    "glob",
    "code",
    "web_search",
    "web_fetch",
    "introspect",
    "use_subagent",
    "report_issue"
  ],
  "resources": [
    "file://.kiro/steering/**/*.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "bash .kiro/hooks/enforce-nohup.sh"
      },
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/enforce-freeprocess.sh"
      }
    ]
  }
}
